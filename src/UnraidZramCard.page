<?php
/**
 * <module_context>
 *   <name>UnraidZramCard</name>
 *   <description>Settings page for ZRAM Card plugin — tiered swap management UI</description>
 *   <dependencies>zram_config</dependencies>
 * </module_context>
 */
$docroot = $docroot ?? $_SERVER['DOCUMENT_ROOT'] ?: '/usr/local/emhttp';
require_once "$docroot/plugins/unraid-zram-card/zram_config.php";

// Handle settings form POST
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['save_settings'])) {
    $updates = [
        'enabled'             => ($_POST['enabled'] ?? 'yes') === 'yes' ? 'yes' : 'no',
        'refresh_interval'    => max(1000, intval($_POST['refresh_interval'] ?? 3000)),
        'collection_interval' => max(1, intval($_POST['collection_interval'] ?? 3)),
        'swappiness'          => max(0, min(100, intval($_POST['swappiness'] ?? 100))),
        'debug'               => ($_POST['debug'] ?? '') === 'yes' ? 'yes' : 'no',
        'console_visible'     => ($_POST['console_visible'] ?? 'yes') === 'yes' ? 'yes' : 'no',
        'zram_size'           => $_POST['zram_size'] ?: 'auto',
        'zram_percent'        => max(25, min(75, intval($_POST['zram_percent'] ?? 50))),
        'zram_algo'           => $_POST['zram_algo'] ?: 'zstd',
    ];
    zram_config_write($updates);
    zram_debug_reset();
    exec("sysctl -q vm.swappiness=" . escapeshellarg($updates['swappiness']));

    // Restart collector to pick up new settings
    $initScript = "$docroot/plugins/unraid-zram-card/zram_init.sh";
    if (file_exists($initScript)) exec("nohup $initScript > /dev/null 2>&1 & disown");

    echo "<div class='updated'>Settings Saved</div>";
}

$settings = zram_config_read();
$ourDev = zram_get_our_device();
$csrf = $var['csrf_token'] ?? '';

// Device info
$devSize = '-'; $devAlgo = '-'; $devPrio = '-'; $devActive = false;
if ($ourDev && file_exists("/sys/block/$ourDev")) {
    $devActive = true;
    exec("zramctl --bytes --noheadings --raw --output DISKSIZE,ALGORITHM /dev/$ourDev 2>/dev/null", $di);
    if (!empty($di)) {
        $dp = preg_split('/\s+/', trim($di[0]));
        $devSize = intval($dp[0] ?? 0);
        $devAlgo = $dp[1] ?? '-';
    }
    exec('swapon --noheadings --show=NAME,PRIO 2>/dev/null', $sp);
    foreach ($sp as $sl) {
        $spp = preg_split('/\s+/', trim($sl));
        if (count($spp) >= 2 && basename($spp[0]) === $ourDev) { $devPrio = $spp[1]; break; }
    }
}

// Auto-size calculation for display
$memKb = 0;
$meminfo = @file_get_contents('/proc/meminfo') ?: '';
if (preg_match('/MemTotal:\s+(\d+)/', $meminfo, $mm)) $memKb = intval($mm[1]);
$autoSizeMB = intval($memKb * intval($settings['zram_percent']) / 100 / 1024);
$memTotalGB = round($memKb / 1048576, 1);

// Supported algorithms
$algos = ['zstd', 'lz4', 'lzo', 'deflate'];
// Try to read from any zram device
foreach (glob('/sys/block/zram*/comp_algorithm') as $af) {
    $raw = str_replace(['[', ']'], '', @file_get_contents($af));
    $algos = preg_split('/\s+/', trim($raw));
    break;
}

// SSD swap status
$ssdPath = $settings['ssd_swap_path'] ?? '';
$ssdActive = false;
if ($ssdPath && file_exists($ssdPath)) {
    $swaps = @file_get_contents('/proc/swaps') ?: '';
    $ssdActive = strpos($swaps, $ssdPath) !== false;
}

$fmtB = function($b) { $u = ['B','KB','MB','GB','TB']; if ($b < 1) return '0 B'; $p = min(floor(log(max($b,1))/log(1024)), 4); return round($b/pow(1024,$p), 1).' '.$u[$p]; };
echo "<script>window.ZRAM_PAGE={CSRF:'".addslashes($csrf)."',API:'/plugins/unraid-zram-card/zram_actions.php',MEM_KB:$memKb,selectedMount:''};</script>";
echo '<script src="/plugins/unraid-zram-card/js/zram-settings.js?v='.time().'"></script>';
?>

