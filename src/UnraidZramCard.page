                    <option value="auto" <?php echo ($settings['zram_size'] === 'auto') ? 'selected' : ''; ?>>Auto</option>
                    <option value="custom" <?php echo ($settings['zram_size'] !== 'auto') ? 'selected' : ''; ?>>Custom</option>
                </select>
                <span id="zram_auto_info" style="margin-left:8px;font-size:0.9em;opacity:0.7;">
