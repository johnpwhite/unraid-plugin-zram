                </strong>
<?php if ($devActive): ?>
                <div style="font-size:0.85em;opacity:0.7;margin-top:2px;">
                    <?php echo $fmtB($devSize); ?> &middot; <?php echo htmlspecialchars($devAlgo); ?> &middot; priority <?php echo $devPrio; ?>
                </div>
<?php endif; ?>
            </div>
        </div>
        <dl>
